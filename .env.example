# Where generated bookmark artifacts should be written.
# Keep this outside the repo. Example:
# BOOKMARKS_PATH=/Users/<you>/Documents/bookmarks-data
# Legacy INFLUENCE_PATH is still supported for backwards compatibility.
BOOKMARKS_PATH=/Users/<you>/bookmarks-data

# X bookmark sync source.
# auto = prefer file input if present, otherwise use API auth if available.
X_BOOKMARKS_SOURCE=api

# Optional file-mode input for manual imports or fallback workflows.
X_BOOKMARKS_INPUT_PATH=

# X OAuth 2.0 PKCE configuration for API mode.
X_API_BASE_URL=https://api.x.com/2
X_BOOKMARKS_ENDPOINT_TEMPLATE=/users/{user_id}/bookmarks
X_CLIENT_ID=
X_REDIRECT_URI=http://127.0.0.1:8741/callback
X_OAUTH_SCOPES=bookmark.read tweet.read users.read offline.access

# Optional direct overrides if you already have a valid user access token.
# Normally you should use `python3 -m bookmarks_cli auth x-login` instead of setting these.
X_USER_ACCESS_TOKEN=
X_USER_ID=

# Safety cap for incremental sync runs.
X_BOOKMARKS_LIMIT=100
